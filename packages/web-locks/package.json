{
  "name": "@universal-lock/web-locks",
  "version": "0.0.2",
  "description": "Web Locks API backend for universal-lock",
  "sideEffects": false,
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "/dist"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lucasrainett/universal-lock",
    "directory": "packages/web-locks"
  },
  "keywords": [
    "universal-lock",
    "lock",
    "mutex",
    "web-locks",
    "browser",
    "backend"
  ],
  "author": {
    "name": "Lucas Rainett",
    "email": "lucas@rainett.dev",
    "url": "https://github.com/lucasrainett"
  },
  "license": "MIT",
  "dependencies": {
    "@universal-lock/types": "workspace:*"
  }
}
